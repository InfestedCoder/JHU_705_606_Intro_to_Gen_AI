\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}System Architecture}{4}{subsection.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Optimization Log Copilot system architecture. Raw Rose solver logs (JSON metrics + stdout) are parsed into a \texttt  {SolverLogFeatures} representation. Bottleneck detection runs along two parallel paths -- heuristic threshold rules and a PyTorch MLP classifier -- both producing a five-label multi-label vector. Diagnostic generation uses label-conditioned retrieval over a curated knowledge base (top-$k$ entries filtered to the detected labels) fed to \texttt  {Llama-3.2-1B-Instruct}. A 30-run hand-reviewed gold subset evaluates both the bottleneck labels (per-label F1, ROC-AUC) and the generated diagnostics (qualitative review).}}{5}{figure.1}\protected@file@percent }
\newlabel{fig:architecture}{{1}{5}{Optimization Log Copilot system architecture. Raw Rose solver logs (JSON metrics + stdout) are parsed into a \texttt {SolverLogFeatures} representation. Bottleneck detection runs along two parallel paths -- heuristic threshold rules and a PyTorch MLP classifier -- both producing a five-label multi-label vector. Diagnostic generation uses label-conditioned retrieval over a curated knowledge base (top-$k$ entries filtered to the detected labels) fed to \texttt {Llama-3.2-1B-Instruct}. A 30-run hand-reviewed gold subset evaluates both the bottleneck labels (per-label F1, ROC-AUC) and the generated diagnostics (qualitative review)}{figure.1}{}}
